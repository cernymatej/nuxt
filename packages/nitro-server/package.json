{
  "name": "@nuxt/nitro-server",
  "version": "4.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/nitro-server"
  },
  "description": "Nitro server integration for Nuxt",
  "homepage": "https://nuxt.com",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "augments": [
        "./dist/augments.d.mts"
      ],
      "h3": [
        "./dist/h3.d.mts"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./augments": "./src/augments.ts",
    "./h3": "./src/h3.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "test:attw": "node ../../scripts/test-attw.ts"
  },
  "dependencies": {
    "@nuxt/devalue": "^2.0.2",
    "@nuxt/kit": "workspace:*",
    "@unhead/vue": "catalog:app-runtime",
    "@vue/shared": "catalog:app-runtime",
    "consola": "catalog:app-runtime",
    "defu": "catalog:app-runtime",
    "destr": "catalog:nitro-runtime",
    "devalue": "catalog:app-runtime",
    "errx": "catalog:app-runtime",
    "escape-string-regexp": "catalog:build",
    "exsolve": "catalog:build",
    "h3": "^1.15.11",
    "impound": "catalog:build",
    "klona": "catalog:app-runtime",
    "mocked-exports": "catalog:build",
    "nitropack": "^2.13.4",
    "nostics": "catalog:app-runtime",
    "nypm": "^0.6.8",
    "ohash": "catalog:app-runtime",
    "pathe": "catalog:app-runtime",
    "rou3": "^0.9.1",
    "std-env": "catalog:build",
    "ufo": "catalog:app-runtime",
    "unctx": "catalog:app-runtime",
    "unstorage": "catalog:nitro-runtime",
    "vue": "catalog:app-runtime",
    "vue-bundle-renderer": "catalog:app-runtime",
    "vue-devtools-stub": "catalog:vue"
  },
  "peerDependencies": {
    "@babel/plugin-proposal-decorators": "^7.25.0 || ^8.0.0",
    "@babel/plugin-syntax-typescript": "^7.25.0 || ^8.0.0",
    "@rollup/plugin-babel": "^6.0.0 || ^7.0.0",
    "nuxt": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@babel/plugin-proposal-decorators": {
      "optional": true
    },
    "@babel/plugin-syntax-typescript": {
      "optional": true
    },
    "@rollup/plugin-babel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "catalog:dev",
    "@babel/plugin-syntax-typescript": "catalog:dev",
    "@nuxt/schema": "workspace:*",
    "@rollup/plugin-babel": "catalog:dev",
    "nuxt": "workspace:*",
    "tsdown": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "engines": {
    "node": "^22.19.0 || ^24.11.0 || >=26.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./augments": "./dist/augments.mjs",
      "./h3": "./dist/h3.mjs",
      "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts"
  }
}
